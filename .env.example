# Backend Server Settings
PORT=3001

# Host machine's LAN IP — used by Nginx server_name and frontend
# Replace <HOST_IP> with your host machine's actual LAN IP (e.g. 192.168.1.100)
SERVER_NAME=<HOST_IP>

# Nginx External Port (single external entry point for all HTTP/WS traffic)
# Change this if port 443 is already in use on your host machine
NGINX_PORT=443

# Allowed CORS origins for the backend API (comma-separated).
# Defaults to https://<SERVER_NAME>[:<NGINX_PORT>] when not set.
# Add your Cloudflare Tunnel domain here if you use one, e.g.:
# ALLOWED_ORIGINS=https://192.168.1.100,https://your-tunnel.trycloudflare.com
# ALLOWED_ORIGINS=

# LiveKit Credentials (must match keys defined in livekit.yaml)
# Use strong random values in production
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret_min_32_chars

# LiveKit URL for Server-Side Use (within Docker network, do not change)
LIVEKIT_URL=ws://livekit:7880

# LiveKit URL for Frontend (accessed via browser from external devices)
# Use wss:// with the /livekit path so Nginx can proxy it to LiveKit
# Replace <HOST_IP> with your host machine's actual LAN IP (e.g. 192.168.1.100)
VITE_LIVEKIT_URL=wss://<HOST_IP>/livekit

# Host machine's LAN IP — used by the frontend for links and redirects
# Replace <HOST_IP> with your host machine's actual LAN IP (e.g. 192.168.1.100)
VITE_APP_DOMAIN=<HOST_IP>

# Google Gemini API（AI 助理）
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# 逗號分隔多個 model，遇到 503/429/UNAVAILABLE 會自動 fallback 到下一個
GEMINI_MODEL=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite

# ── Firebase 身分驗證（對應 SDGs_journey 的同一個 Firebase Project）──────────
# 從 Firebase Console > Project Settings > Your apps 取得
VITE_FIREBASE_API_KEY=<YOUR_FIREBASE_API_KEY>
VITE_FIREBASE_AUTH_DOMAIN=<YOUR_FIREBASE_AUTH_DOMAIN>
VITE_FIREBASE_PROJECT_ID=<YOUR_FIREBASE_PROJECT_ID>
VITE_FIREBASE_STORAGE_BUCKET=<YOUR_FIREBASE_STORAGE_BUCKET>
VITE_FIREBASE_MESSAGING_SENDER_ID=<YOUR_FIREBASE_MESSAGING_SENDER_ID>
VITE_FIREBASE_APP_ID=<YOUR_FIREBASE_APP_ID>

# SDGs 後端 API Base URL (用於向 SDGs 系統進行身分驗證並取得 role)
VITE_SDGS_API_BASE_URL=<API>
